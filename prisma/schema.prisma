// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
}

model Project {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  short_desc     String
  long_desc      String?
  thumbnail_url  String?
  gallery_urls   String    // SQLite doesn't support String[] natively, we will store JSON string
  github_url     String?
  demo_url       String?
  status         String    @default("draft") // draft / published / featured
  is_featured    Boolean   @default(false)
  sort_order     Int       @default(0)
  start_date     DateTime?
  end_date       DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  categories     ProjectCategory[]
  techs          ProjectTech[]
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  color String

  projects ProjectCategory[]
}

model ProjectCategory {
  project_id  String
  category_id String
  
  project  Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([project_id, category_id])
}

model TechStack {
  id       String @id @default(uuid())
  name     String @unique
  icon_url String?
  color    String?

  projects ProjectTech[]
}

model ProjectTech {
  project_id String
  tech_id    String
  
  project Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tech    TechStack @relation(fields: [tech_id], references: [id], onDelete: Cascade)

  @@id([project_id, tech_id])
}

model Skill {
  id         String @id @default(uuid())
  name       String
  category   String // Frontend/Backend/dll
  level      Int    // 1-100
  icon_url   String?
  sort_order Int    @default(0)
}

model Experience {
  id           String    @id @default(uuid())
  type         String    // work / education / achievement
  title        String
  organization String
  description  String?
  start_date   DateTime
  end_date     DateTime?
  sort_order   Int       @default(0)
}

model Message {
  id           String   @id @default(uuid())
  sender_name  String
  sender_email String
  message      String
  is_read      Boolean  @default(false)
  ip_address   String?
  created_at   DateTime @default(now())
}

model Profile {
  id               String  @id @default(uuid())
  name             String
  headline         String?
  bio              String?
  photo_url        String?
  cv_url           String?
  location         String?
  github_url       String?
  linkedin_url     String?
  twitter_url      String?
  email_contact    String?
  meta_title       String?
  meta_description String?
}

model StudyFile {
  id          String   @id @default(uuid())
  name        String
  type        String
  subject     String?
  semester    String?
  category    String?
  size        String
  description String?
  file_url    String   // Path to the actual file
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model DocumentSummary {
  id         String   @id @default(uuid())
  title      String
  summary    String
  key_points String   // JSON string array
  file_type  String
  file_name  String
  file_size  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
