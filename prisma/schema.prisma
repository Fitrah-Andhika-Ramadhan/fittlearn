generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model Project {
  id            String            @id @default(uuid())
  title         String
  slug          String            @unique
  short_desc    String
  long_desc     String?
  thumbnail_url String?
  gallery_urls  String
  github_url    String?
  demo_url      String?
  status        String            @default("draft")
  is_featured   Boolean           @default(false)
  sort_order    Int               @default(0)
  start_date    DateTime?
  end_date      DateTime?
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  categories    ProjectCategory[]
  techs         ProjectTech[]
}

model Category {
  id       String            @id @default(uuid())
  name     String            @unique
  slug     String            @unique
  color    String
  projects ProjectCategory[]
}

model ProjectCategory {
  project_id  String
  category_id String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@id([project_id, category_id])
}

model TechStack {
  id       String        @id @default(uuid())
  name     String        @unique
  icon_url String?
  color    String?
  projects ProjectTech[]
}

model ProjectTech {
  project_id String
  tech_id    String
  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tech       TechStack @relation(fields: [tech_id], references: [id], onDelete: Cascade)

  @@id([project_id, tech_id])
}

model Skill {
  id         String  @id @default(uuid())
  name       String
  category   String
  level      Int
  icon_url   String?
  sort_order Int     @default(0)
}

model Experience {
  id           String    @id @default(uuid())
  type         String
  title        String
  organization String
  description  String?
  key_points   String?   // JSON array of achievement strings
  start_date   DateTime
  end_date     DateTime?
  sort_order   Int       @default(0)
}

model Message {
  id           String   @id @default(uuid())
  sender_name  String
  sender_email String
  message      String
  is_read      Boolean  @default(false)
  ip_address   String?
  created_at   DateTime @default(now())
}

model Profile {
  id               String  @id @default(uuid())
  name             String
  headline         String?
  bio              String?
  photo_url        String?
  cv_url           String?
  location         String?
  github_url       String?
  linkedin_url     String?
  twitter_url      String?
  email_contact    String?
  phone            String?
  meta_title       String?
  meta_description String?

  // Homepage hero section
  hero_tagline     String?   // Big background text e.g. "Development"
  hero_intro       String?   // Small label e.g. "Hello, I Am"
  cta_primary_text String?   // e.g. "See Portfolio"
  cta_secondary_text String? // e.g. "Download CV"

  // Contact section
  contact_intro    String?   // Paragraph in contact box

  // Portfolio page (homepage section)
  portfolio_title  String?   // e.g. "My Portfolio"
  portfolio_subtitle String? // Subtitle text

  // Portfolio page (actual page)
  portfolio_skills_title      String? // e.g. "Technical Skills"
  portfolio_projects_title    String? // e.g. "Featured Projects"
  portfolio_experience_title  String? // e.g. "Experience & Education"
  portfolio_btn_contact       String? // e.g. "Contact Me"
  portfolio_btn_github        String? // e.g. "GitHub"
  portfolio_btn_files         String? // e.g. "My Study Files"
}

model StudyFile {
  id          String   @id @default(uuid())
  name        String
  type        String
  subject     String?
  semester    String?
  category    String?
  size        String
  description String?
  file_url    String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model DocumentSummary {
  id         String   @id @default(uuid())
  title      String
  summary    String
  key_points String
  file_type  String
  file_name  String
  file_size  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Guestbook {
  id         String   @id @default(uuid())
  name       String
  message    String
  is_approved Boolean @default(true)
  created_at DateTime @default(now())
}
